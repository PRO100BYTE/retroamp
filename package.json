{
  "name": "retroamp",
  "version": "1.0.0",
  "description": "Retro DOS-style music player for Windows — spectrum visualizer, playlists, drag & drop",
  "main": "out/main/index.js",
  "author": "PRO100BYTE",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/tauri-runner.cjs dev",
    "dev:web": "vite --config vite.renderer.config.mjs",
    "build": "node scripts/tauri-runner.cjs build",
    "build:web": "vite build --config vite.renderer.config.mjs",
    "preview": "vite preview --config vite.renderer.config.mjs",
    "tauri:dev": "node scripts/tauri-runner.cjs dev",
    "tauri:build": "node scripts/tauri-runner.cjs build",
    "ci": "npm run build:web"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "howler": "^2.2.4",
    "music-metadata": "^10.9.1",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.2.0",
    "vue": "^3.5.34"
  }
}
