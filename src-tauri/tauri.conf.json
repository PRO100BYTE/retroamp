{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RetroAmp",
  "version": "0.1.0",
  "identifier": "com.pro100byte.retroamp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node scripts/vite-runner.cjs dev",
    "beforeBuildCommand": "node scripts/vite-runner.cjs build"
  },
  "app": {
    "windows": [
      {
        "title": "RetroAmp",
        "width": 800,
        "height": 600,
        "minWidth": 330,
        "minHeight": 330,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
